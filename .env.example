# Orchestrator (for orchestrator mode)
ORCHESTRATOR_URL=http://localhost:8888
APP_NAME=multi_agent

# Agent (for a2a mode)
CAMPAIGN_AGENT_URL=http://localhost:8777

# User
USER_ID=your-email@example.com
EAM_PROJECT_ID=your-project-id

# JWT
USE_REAL_JWT=false

# LLM Controller
LITELLM_MODEL=your-model
LITELLM_REVIEW_MODEL=your-review-model
LITELLM_API_KEY=your-key-here
LITELLM_API_BASE=https://your-api-base

# Langfuse (optional)
LANGFUSE_PROJECT_ID=your-langfuse-project-id
